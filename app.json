{
  "expo": {
    "name": "Chawp",
    "slug": "Chawp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/chawp.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/chawp.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/chawp.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/chawp.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/chawp.png",
        "resizeMode": "cover",
        "backgroundColor": "#000000"
      },
      "package": "com.stephen_j.Chawp",
      "googleServicesFile": "./google-services.json",
      "permissions": ["NOTIFICATIONS", "RECEIVE_BOOT_COMPLETED", "VIBRATE"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "chawp"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "scheme": "chawp",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/chawp.png",
          "color": "#FF6B6B"
        }
      ],
      "expo-web-browser"
    ],
    "web": {
      "favicon": "./assets/chawp.png"
    },
    "extra": {
      "eas": {
        "projectId": "b13177a5-3d74-41a9-b0d4-b0783b8daea2"
      }
    }
  }
}
